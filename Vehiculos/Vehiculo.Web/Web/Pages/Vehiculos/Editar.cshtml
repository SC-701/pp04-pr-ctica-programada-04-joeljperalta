@page
@model Web.Pages.Vehiculos.EditarModel
@{
}

<h1>Editar vehículo</h1>

<div class="container">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">

        <form method="post">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label for="marcas" class="form-label">Marca</label>
                <select asp-for="marcaseleccionada"
                        class="form-select"
                        asp-items="Model.marcas"
                        id="marcas"
                        onchange="fetchModelos()">
                    <option value="">Seleccione una marca</option>
                </select>
            </div>

            <div class="mb-3">
                <label for="modelos" class="form-label">Modelo</label>
                <select asp-for="modeloseleccionado"
                        class="form-select"
                        asp-items="Model.modelos"
                        id="modelos">
                    <option value="">Seleccione un modelo</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.Placa" class="form-label"></label>
                <input asp-for="vehiculoResponse.Placa" class="form-control" />
                <span asp-validation-for="vehiculoResponse.Placa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.Precio" class="form-label"></label>
                <input asp-for="vehiculoResponse.Precio" class="form-control" />
                <span asp-validation-for="vehiculoResponse.Precio" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.Anio" class="form-label"></label>
                <input asp-for="vehiculoResponse.Anio" class="form-control" />
                <span asp-validation-for="vehiculoResponse.Anio" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.Color" class="form-label"></label>
                <input asp-for="vehiculoResponse.Color" class="form-control" />
                <span asp-validation-for="vehiculoResponse.Color" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.CorreoPropietario" class="form-label"></label>
                <input asp-for="vehiculoResponse.CorreoPropietario" class="form-control" />
                <span asp-validation-for="vehiculoResponse.CorreoPropietario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="vehiculoResponse.TelefonoPropietario" class="form-label"></label>
                <input asp-for="vehiculoResponse.TelefonoPropietario" class="form-control" />
                <span asp-validation-for="vehiculoResponse.TelefonoPropietario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                <input type="submit" value="Editar" class="btn btn-success" />
            </div>

            <input type="hidden" asp-for="vehiculoResponse.Id" />
            <input type="hidden" asp-for="modeloseleccionado" />
            <input type="hidden" asp-for="marcaseleccionada" />

        </form>

    </div>
</div>

@section Scripts {
    <script>

        async function fetchModelos() {

            const marcaId = document.getElementById("marcas").value;

            if (!marcaId) return;

            try {

                const respuesta = await fetch(`?handler=ObtenerModelos&marcaID=${marcaId}`);
                const modelos = await respuesta.json();

                const modelosSelect = document.getElementById("modelos");

                modelosSelect.innerHTML = '<option value="">Seleccione un modelo</option>';

                modelos.forEach(modelo => {

                    const option = document.createElement("option");
                    option.value = modelo.id;
                    option.text = modelo.nombre;

                    modelosSelect.appendChild(option);

                });

            } catch (error) {

                console.error("Error obteniendo modelos", error);

            }
        }

    </script>
}
